  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from RFC 5869." },
    "EmptySalt": { "bugType": "EDGE_CASE", "description": "Salt is empty; HKDF defaults it to HashLen zero bytes." },
    "EmptyInfo": { "bugType": "EDGE_CASE", "description": "Info is empty; expand inputs become just T(i-1) || counter." },
    "EmptyIKM": { "bugType": "EDGE_CASE", "description": "IKM is empty; extract step is HMAC over an empty message." },
    "ShortOutput": { "bugType": "EDGE_CASE", "description": "Output length 1 byte." },
    "OutputBoundary": { "bugType": "EDGE_CASE", "description": "Output length is an exact multiple of HashLen." },
    "ExpandCounter": { "bugType": "MISSING_STEP", "description": "Expand step appends a 1-byte (not 4-byte) counter that advances from 0x01.", "effect": "Bug if counter byte width is wrong or counter does not advance." },
    "MaxOutput": { "bugType": "EDGE_CASE", "description": "Output length equals 255 * HashLen, the RFC 5869 maximum." },
    "LongInputs": { "bugType": "BASIC", "description": "All inputs span multiple hash blocks." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
