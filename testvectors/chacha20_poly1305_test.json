  "schema": "tadashi_aead_v1.json",
  "header": [
    "ChaCha20-Poly1305 AEAD per RFC 8439, with bug-catching cases targeting padding boundaries, length encoding, counter-start, and tag-verification rejection.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from an RFC or authoritative source." },
    "BothEmpty": { "bugType": "EDGE_CASE", "description": "Both AAD and plaintext are empty.", "effect": "MAC input collapses to just the 16-byte length block." },
    "AadOnly": { "bugType": "EDGE_CASE", "description": "MAC input is dominated by the AAD section." },
    "AadPaddingZero": { "bugType": "EDGE_CASE", "description": "AAD length is exactly a multiple of 16.", "effect": "Bug if implementation always adds a zero-pad block." },
    "CtPaddingZero": { "bugType": "EDGE_CASE", "description": "Ciphertext length is exactly a multiple of 16.", "effect": "Bug if implementation always adds a zero-pad block." },
    "LengthEncoding": { "bugType": "EDGE_CASE", "description": "AAD and ciphertext lengths chosen to expose BE-vs-LE confusion in the 8-byte length fields.", "effect": "Tag changes if length fields are encoded big-endian or with wrong width." },
    "CounterStart": { "bugType": "MISSING_STEP", "description": "Encryptor must start ChaCha20 at counter=1; block 0 is reserved for the Poly1305 one-time key.", "effect": "If counter starts at 0, first plaintext block XORs against MAC key bytes." },
    "WrongMacKey": { "bugType": "MISSING_STEP", "description": "The Poly1305 key is derived from ChaCha20 block 0 with counter=0, key, nonce.", "effect": "Wrong block or counter yields wrong MAC key and wrong tag." },
    "TagForgery": { "bugType": "AUTH_BYPASS", "description": "Modified tag, ciphertext, or AAD with otherwise valid encryption.", "effect": "Decrypt must reject; bug if implementation returns plaintext without verifying tag." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result.", "effect": "Catches hex parser that reverses byte order on parse or emit." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles.", "effect": "Catches hex parser that swaps nibbles within a byte." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
