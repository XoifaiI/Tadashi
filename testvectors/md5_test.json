    "EmptyMessage": { "bugType": "EDGE_CASE", "description": "Zero-length input." },
    "BlockBoundary": { "bugType": "EDGE_CASE", "description": "Message length is exactly N * 64 bytes." },
    "PaddingFitsLastBlock": { "bugType": "EDGE_CASE", "description": "0x80 + 8-byte length fit in the same block as the last data byte." },
    "PaddingNewBlock": { "bugType": "EDGE_CASE", "description": "Padding spills into a second block." },
    "BlockLoop": { "bugType": "BASIC", "description": "Long input forces many block iterations." },
    "LengthEncodingBitsVsBytes": { "bugType": "EDGE_CASE", "description": "Bit count vs byte count differ; catches bytes-instead-of-bits encoding." },
    "LengthEncodingEndian": { "bugType": "EDGE_CASE", "description": "Bit length occupies non-low byte of the 8-byte BE length field." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
