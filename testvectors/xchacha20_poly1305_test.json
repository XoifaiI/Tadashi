{
  "algorithm": "XCHACHA20-POLY1305",
  "generatorVersion": "Tadashi 0.1.0",
  "schema": "tadashi_aead_v1.json",
  "header": [
    "XChaCha20-Poly1305 AEAD per draft-irtf-cfrg-xchacha-03, with bug-catching cases targeting padding, length encoding, nonce split, HChaCha20 subkey derivation, counter-start, and tag rejection.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from an authoritative draft." },
    "BothEmpty": { "bugType": "EDGE_CASE", "description": "Both AAD and plaintext are empty.", "effect": "MAC input collapses to just the 16-byte length block." },
    "AadOnly": { "bugType": "EDGE_CASE", "description": "MAC input is dominated by the AAD section." },
    "AadPaddingZero": { "bugType": "EDGE_CASE", "description": "AAD length is exactly a multiple of 16.", "effect": "Bug if implementation always adds a zero-pad block." },
    "CtPaddingZero": { "bugType": "EDGE_CASE", "description": "Ciphertext length is exactly a multiple of 16.", "effect": "Bug if implementation always adds a zero-pad block." },
    "LengthEncoding": { "bugType": "EDGE_CASE", "description": "AAD and ciphertext lengths chosen to expose BE-vs-LE confusion in the 8-byte length fields." },
    "CounterStart": { "bugType": "MISSING_STEP", "description": "Downstream ChaCha20 (post HChaCha20) must start at counter=1; block 0 is for the Poly1305 one-time key." },
    "WrongMacKey": { "bugType": "MISSING_STEP", "description": "Poly1305 otk is the first 32 bytes of downstream ChaCha20 block 0 keystream." },
    "NonceSplit": { "bugType": "MISSING_STEP", "description": "First 16 bytes of the 24-byte nonce go to HChaCha20; last 8 bytes prefixed with 4 zero bytes form the downstream ChaCha20 nonce." },
    "HChaCha20InitialStateAdd": { "bugType": "MISSING_STEP", "description": "HChaCha20 must NOT add the initial state at the end of its rounds (unlike regular ChaCha20). Output = state[0..4] || state[12..16] post-rounds, no add." },
    "TagForgery": { "bugType": "AUTH_BYPASS", "description": "Modified tag, ciphertext, AAD, or nonce with otherwise valid encryption.", "effect": "Decrypt must reject." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
