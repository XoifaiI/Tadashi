{
  "algorithm": "ED25519",
  "generatorVersion": "Tadashi 0.1.0",
  "schema": "tadashi_eddsa_v1.json",
  "header": [
    "Ed25519 per RFC 8032 with bug-catching cases beyond Wycheproof: public-key-derivation KATs, S-range boundary tests, the strict-form top-3-bits-of-S check, non-canonical y encodings, small-order public-key rejection, and deterministic-signing assertions.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch.",
    "Tests with non-empty sk also assert: PublicKey(sk) == pk AND Sign(sk, msg) == sig. Verify-only tests have empty sk."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from RFC 8032 §7.1." },
    "KeyDerivation": { "bugType": "MISSING_STEP", "description": "PublicKey(SK) = encode(MulG(clamp(SHA-512(SK)[0..32]))); tests the full derivation chain." },
    "ScalarClamping": { "bugType": "MISSING_STEP", "description": "Scalar clamping clears bits 0-2 of byte 0 and clears bit 7 / sets bit 6 of byte 31." },
    "SignDeterministic": { "bugType": "BASIC", "description": "Ed25519 signing is deterministic; the same (sk, msg) must produce the same sig." },
    "LongMessage": { "bugType": "EDGE_CASE", "description": "Message spans many SHA-512 blocks; exercises multi-block paths in both the nonce hash and the challenge hash." },
    "MessageBlockBoundary": { "bugType": "EDGE_CASE", "description": "Message length chosen so that the nonce-hash or challenge-hash input lands at a SHA-512 block boundary." },
    "ZeroInput": { "bugType": "EDGE_CASE", "description": "All-zero secret key; catches impls that special-case zero inputs." },
    "ScalarSRange": { "bugType": "AUTH_BYPASS", "description": "S must be in [0, L) per RFC 8032 §5.1.7 step 1.", "effect": "Bug if impl skips range check or uses S mod L." },
    "SHighBits": { "bugType": "AUTH_BYPASS", "description": "Top 3 bits of S byte 31 must be zero since S < L < 2^253.", "effect": "Some impls fast-fail on the 0xE0 mask before computing the full range check." },
    "NonCanonicalY": { "bugType": "AUTH_BYPASS", "description": "Point encoding with y >= p (= 2^255 - 19) is non-canonical and must be rejected." },
    "SmallOrderPK": { "bugType": "AUTH_BYPASS", "description": "Public key encodes a small-order point (order 1, 2, 4, or 8); strict impls reject these." },
    "SmallOrderR": { "bugType": "AUTH_BYPASS", "description": "Signature R component is a small-order point." },
    "MessageBitFlip": { "bugType": "AUTH_BYPASS", "description": "Message bit modified; sig must not verify." },
    "PKBitFlip": { "bugType": "AUTH_BYPASS", "description": "Public key bit modified; sig must not verify." },
    "SBitFlip": { "bugType": "AUTH_BYPASS", "description": "S bit modified; sig must not verify." },
    "RBitFlip": { "bugType": "AUTH_BYPASS", "description": "R bit modified; sig must not verify." },
    "BitFlip": { "bugType": "AUTH_BYPASS", "description": "A single bit was modified somewhere in the (pk, msg, sig) triple." },
    "PKMismatch": { "bugType": "AUTH_BYPASS", "description": "Signature was produced under a different secret key than the public key being checked against." },
    "WrongMessage": { "bugType": "AUTH_BYPASS", "description": "Signature is well-formed and matches the public key, but is bound to a different message." },
    "CrossKey": { "bugType": "AUTH_BYPASS", "description": "Cross-key forgery attempt." },
    "PointNotOnCurve": { "bugType": "AUTH_BYPASS", "description": "Encoded y-coordinate yields a non-square x^2 = (y^2 - 1) / (d*y^2 + 1); the encoded point does not exist on Edwards25519." },
    "PKSignBitFlip": { "bugType": "AUTH_BYPASS", "description": "Public-key sign-of-x bit (bit 255) flipped from canonical; encodes the negation of the original point." },
    "RSignBitFlip": { "bugType": "AUTH_BYPASS", "description": "R sign-of-x bit (bit 255) flipped from canonical." },
    "RSSwapped": { "bugType": "AUTH_BYPASS", "description": "Signature halves R and S swapped." },
    "Structural": { "bugType": "AUTH_BYPASS", "description": "Sig is malformed at the structural level rather than at a per-byte level." },
    "CofactorVerification": { "bugType": "SPEC_AMBIGUOUS", "description": "Tests whether the verifier multiplies by the cofactor (8) before the zero-check, exposing the ZIP-215 / LIBSODIUM / strict flavor distinction.", "effect": "Different Ed25519 flavors (LIBSODIUM-strict, ed25519-dalek, ZIP-215) give different verdicts. rbx-crypto matches ZIP-215." },
    "SpecCheck": { "bugType": "SPEC_AMBIGUOUS", "description": "Test vector from the Chalkias-Garillot-Kondi speccheck suite (github.com/novifinancial/ed25519-speccheck), designed to expose disagreements between Ed25519 implementations." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
