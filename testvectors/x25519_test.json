  "schema": "tadashi_kex_v1.json",
  "header": [
    "X25519 ECDH per RFC 7748, with bug-catching cases beyond Wycheproof: dedicated public-key-derivation tests, scalar-clamping demonstrations (low bits, bit 7, bit 6), bit-255 u-coordinate mask check, non-canonical u reduction (u=p, u=p+1), small-order-PK zero-output tests, and full Alice/Bob DH round-trip from §6.1.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch.",
    "Tests with pk = base (= 0x09 || 0^31) are public-key-derivation tests; their shared is the derived public key."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from RFC 7748." },
    "KeyDerivation": { "bugType": "BASIC", "description": "PublicKey(sk) = Exchange(sk, base); tests the full derivation chain." },
    "DHFlow": { "bugType": "BASIC", "description": "Computing the shared secret across one half of the DH exchange." },
    "DHSymmetry": { "bugType": "BASIC", "description": "Both parties of an X25519 exchange compute the same shared secret." },
    "SelfExchange": { "bugType": "BASIC", "description": "Recursive X25519 with K = u; well-known in RFC 7748 §5.2 as a one-iteration KAT." },
    "SmallOrderPK": { "bugType": "EDGE_CASE", "description": "Their public key is a small-order point on the curve.", "effect": "Output is the all-zero byte string; implementations MAY abort per RFC 7748 §6.1 but rbx-crypto follows the original Curve25519 contract of returning zero." },
    "ZeroOutput": { "bugType": "EDGE_CASE", "description": "Shared output is the all-zero byte string." },
    "NonCanonicalU": { "bugType": "MISSING_STEP", "description": "Their public-key u-coordinate is >= p; RFC 7748 §5 requires reduction mod p.", "effect": "Bug if impl uses u directly without reducing." },
    "Bit255Mask": { "bugType": "MISSING_STEP", "description": "u-coordinate bit 255 (high bit of byte 31) must be cleared per RFC 7748 §5.", "effect": "Bug if impl uses u with bit 255 intact." },
    "ScalarClamping": { "bugType": "MISSING_STEP", "description": "Secret key is clamped: clear bits 0, 1, 2 of byte 0; clear bit 7 / set bit 6 of byte 31.", "effect": "Bug if any clamping step is skipped." },
    "ClampLowBits": { "bugType": "MISSING_STEP", "description": "Low 3 bits of byte 0 of SK must be cleared." },
    "ClampHighBit": { "bugType": "MISSING_STEP", "description": "Bit 7 of byte 31 of SK must be cleared." },
    "ClampBit6Set": { "bugType": "MISSING_STEP", "description": "Bit 6 of byte 31 of SK must be SET (forces scalar into [2^254, 2^255))." },
    "ClampingBoundary": { "bugType": "EDGE_CASE", "description": "SK chosen so that the clamped scalar is at the minimum (2^254) or maximum (2^255 - 8) of the clamped range." },
    "TwistPoint": { "bugType": "EDGE_CASE", "description": "u-coordinate is a point on the quadratic twist of Curve25519. The Montgomery ladder produces a defined output; RFC 7748 does not require rejection." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
