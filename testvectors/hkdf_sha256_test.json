    "LongInputs": { "bugType": "BASIC", "description": "All inputs span multiple hash blocks." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
