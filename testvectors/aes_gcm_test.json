{
  "algorithm": "AES-GCM",
  "generatorVersion": "Tadashi 0.1.0",
  "schema": "tadashi_aead_v1.json",
  "header": [
    "AES-GCM AEAD per NIST SP 800-38D, with bug-catching cases targeting GHASH reduction, J0 derivation for non-96-bit IVs, padding boundaries, length encoding, counter start, and tag rejection.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from NIST SP 800-38D." },
    "BothEmpty": { "bugType": "EDGE_CASE", "description": "Both AAD and plaintext are empty.", "effect": "GHASH input collapses to just the 16-byte length block." },
    "AadOnly": { "bugType": "EDGE_CASE", "description": "GHASH input is dominated by the AAD section." },
    "AadPaddingZero": { "bugType": "EDGE_CASE", "description": "AAD length is exactly a multiple of 16.", "effect": "Bug if implementation always emits a zero-pad block." },
    "CtPaddingZero": { "bugType": "EDGE_CASE", "description": "Ciphertext length is exactly a multiple of 16.", "effect": "Bug if implementation always emits a zero-pad block." },
    "BlockBoundary": { "bugType": "EDGE_CASE", "description": "Length is exactly N times 16 bytes." },
    "LastBlockHandling": { "bugType": "EDGE_CASE", "description": "Last block is partial; tests CTR pad16 and partial XOR." },
    "LengthEncoding": { "bugType": "EDGE_CASE", "description": "AAD and CT lengths chosen to expose BE-vs-LE confusion in the 8-byte length fields." },
    "CounterStart": { "bugType": "MISSING_STEP", "description": "GCTR must begin at J0+1; J0 itself is reserved for tag encryption." },
    "J0NonStandardIv": { "bugType": "MISSING_STEP", "description": "IV is not 96 bits, so J0 = GHASH(IV with bit-padding and length block) instead of IV || 0x00000001.", "effect": "Bug if implementation always uses the 96-bit fast path." },
    "GhashReduction": { "bugType": "BASIC", "description": "Pseudorandom inputs that exercise GF(2^128) polynomial reduction with the 0xe1 reduction constant." },
    "TagForgery": { "bugType": "AUTH_BYPASS", "description": "Modified tag, ciphertext, AAD, or IV with otherwise valid encryption.", "effect": "Decrypt must reject." },
    "TagTruncation": { "bugType": "INPUT_VALIDATION", "description": "Tag length less than the 16-byte (128-bit) full-tag; CVE-2025-54887 class. Strict impls reject any tag length != 16.", "effect": "Bug if impl silently accepts shorter tags." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
