  "header": [
    "KMAC128 per NIST SP 800-185, with bug-catching cases targeting key bytepad, customization-prefix domain separation, output-length binding, and squeeze boundaries.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from NIST SP 800-185 §A.4." },
    "EmptyMessage": { "bugType": "EDGE_CASE", "description": "Zero-length data input." },
    "EmptyKey": { "bugType": "EDGE_CASE", "description": "Zero-length key; encoded as left_encode(0)." },
    "EmptyCustom": { "bugType": "EDGE_CASE", "description": "Empty customization string; the N=\"KMAC\" prefix is still present so domain stays cSHAKE." },
    "CustomString": { "bugType": "MISSING_STEP", "description": "Non-empty customization string is bytepadded into the cSHAKE prefix as encode_string(\"KMAC\") || encode_string(S)." },
    "BytepadCustom": { "bugType": "MISSING_STEP", "description": "Long customization string makes the cSHAKE customization prefix span multiple absorption blocks; bytepad is applied to the full prefix, not per block." },
    "DomainSeparator": { "bugType": "MISSING_STEP", "description": "KMAC always uses the cSHAKE 0x04 domain separator (not the plain SHAKE 0x1F)." },
    "BytepadKey": { "bugType": "MISSING_STEP", "description": "Encoded key is bytepadded to the rate before being absorbed." },
    "OutputLengthBinding": { "bugType": "MISSING_STEP", "description": "Output length in bits is right_encoded and appended to the data input before squeezing.", "effect": "Different output lengths produce unrelated outputs." },
    "ShakeSqueezeBoundary": { "bugType": "EDGE_CASE", "description": "Output length at or just over a rate boundary." },
    "LongInput": { "bugType": "BASIC", "description": "Data input spans multiple rate-blocks." },
    "LongKey": { "bugType": "BASIC", "description": "Encoded+bytepadded key spans multiple rate-blocks." },
    "ShortOutput": { "bugType": "EDGE_CASE", "description": "Output length 1 byte." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
