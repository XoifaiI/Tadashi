  "header": [
    "BLAKE2b per RFC 7693, with bug-catching cases targeting the parameter-block-derived initial state, final-block flag, key-block padding, and multi-block compression iteration.",
    "Each non-KAT test's targets[] lists the implementation bugs it is designed to catch."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from RFC 7693 or cross-checked against @noble/hashes." },
    "EmptyMessage": { "bugType": "EDGE_CASE", "description": "Zero-length input." },
    "BlockBoundary": { "bugType": "EDGE_CASE", "description": "Message length is exactly N times the block size (128 bytes)." },
    "PaddingZeroPad": { "bugType": "EDGE_CASE", "description": "Last partial block is zero-padded to 128 bytes before compression." },
    "FinalBlockFlag": { "bugType": "MISSING_STEP", "description": "Only the last compression call has the f0 flag set to all-ones.", "effect": "Bug if flipped on the wrong block." },
    "ParameterBlockOutputLen": { "bugType": "MISSING_STEP", "description": "Output length is XORed into IV[0] byte 0 via the parameter block; different output lengths produce different initial states." },
    "ParameterBlockKeyLen": { "bugType": "MISSING_STEP", "description": "Key length is XORed into IV[0] byte 1 via the parameter block; keyed and unkeyed of same output length differ in initial state." },
    "KeyBlockPad": { "bugType": "MISSING_STEP", "description": "Key is processed as a full block zero-padded to 128 bytes before the data blocks." },
    "BlockLoop": { "bugType": "BASIC", "description": "Long input forces many compression iterations and exercises the 128-bit byte counter." },
    "Keyed": { "bugType": "BASIC", "description": "Keyed Blake2b correctness." },
    "ShortOutput": { "bugType": "EDGE_CASE", "description": "Output length is 1 byte." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
