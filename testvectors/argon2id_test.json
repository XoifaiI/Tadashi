{
  "algorithm": "ARGON2ID",
  "generatorVersion": "Tadashi 0.1.0",
  "schema": "tadashi_kdf_v1.json",
  "header": [
    "Argon2id per RFC 9106, version 0x13. Includes the §5.3 canonical KAT with all six input fields plus parameter sweeps (t, m, p), output-length variations, and the empty/min-bound edge cases.",
    "Wycheproof and NIST CAVP do not publish Argon2 vectors; Tadashi fills this gap."
  ],
  "notes": {
    "Ktv": { "bugType": "BASIC", "description": "Known-answer test from RFC 9106." },
    "MinimumCost": { "bugType": "EDGE_CASE", "description": "Smallest legal t/m/p; smoke test of the core path." },
    "IterationCost": { "bugType": "BASIC", "description": "Time-cost (t) feeds into H0 and the number of memory passes." },
    "MemoryCost": { "bugType": "BASIC", "description": "Memory-cost (m, KiB) determines the total block count." },
    "Parallelism": { "bugType": "BASIC", "description": "Parallelism (p) splits memory into lanes; tests cross-lane reference reads." },
    "OutputLength": { "bugType": "EDGE_CASE", "description": "Output length other than the default 32." },
    "VariableHashIteration": { "bugType": "MISSING_STEP", "description": "RFC 9106 §3.2 specifies a chained Blake2b construction for output lengths > 64 bytes; catches impls that only support the single-call path." },
    "EmptyPassword": { "bugType": "EDGE_CASE", "description": "Zero-length password; tests the H0 length-prefix path." },
    "MinimumSalt": { "bugType": "EDGE_CASE", "description": "Salt at the RFC 9106 minimum length (8 bytes)." },
    "LongSalt": { "bugType": "EDGE_CASE", "description": "Salt longer than the recommended 16 bytes." },
    "SecretOnly": { "bugType": "EDGE_CASE", "description": "Optional Secret (K) present, Associated Data (X) empty." },
    "AdOnly": { "bugType": "EDGE_CASE", "description": "Associated Data (X) present, Secret (K) empty." },
    "SecretAdSeparation": { "bugType": "MISSING_STEP", "description": "Secret (K) and Associated Data (X) occupy distinct positions in H0; catches impls that swap them." },
    "HexByteOrder": { "bugType": "ENCODING", "description": "Bytes are asymmetric; reversed byte order would produce a different result." },
    "HexNibbleOrder": { "bugType": "ENCODING", "description": "Each byte has distinct high and low nibbles." },
    "Pseudorandom": { "bugType": "BASIC", "description": "Standard correctness check on output value." }
  },
  "numberOfTests": 15,
